  "gating_rules": [
    {
      "id": "regulated_no_exclusivity",
      "when": {"is_regulated": true},
      "themes": ["exclusivity", "demographic_targeting", "young_professional"],
      "status": "suppressed",
      "reason": "Regulated affordable housing: exclusivity and demographic-targeting language is a fair-housing and compliance risk, not merely low quality."
    },
    {
      "id": "senior_no_young_framing",
      "when": {"property_type": ["senior", "active_adult"]},
      "themes": ["nightlife", "young_professional"],
      "status": "suppressed",
      "reason": "Senior / active-adult community: nightlife and young-professional framing is off-audience and a fair-housing concern."
    },
    {
      "id": "student_quiet_caution",
      "when": {"property_type": ["student"]},
      "themes": ["quiet_community"],
      "status": "caution-only",
      "reason": "Student housing: a quiet-community angle can conflict with the target audience. Use as caution, not a headline strength."
    }
  ]
